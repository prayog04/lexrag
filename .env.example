# Copy to .env and fill in. Never commit the real .env (it's gitignored).

# Qdrant — localhost:6333 is correct when running ingestion/uvicorn from
# your host machine (with `docker compose up -d qdrant` exposing the port).
# docker-compose.yml overrides this to the internal "qdrant" hostname for
# the containerized api service automatically, so leave this as localhost.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=lexrag_sections

# fastembed model — runs on CPU, no GPU needed. Upgrade to
# BAAI/bge-large-en-v1.5 for better retrieval quality once you have real
# traffic and don't mind the extra latency/RAM.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# https://console.groq.com/keys — free tier is enough for a POC.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

RETRIEVAL_TOP_K=6
